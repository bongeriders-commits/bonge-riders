rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles are public to read (display name shown on reels) — editing
    // your own profile still requires being signed in.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /likes/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Anyone — signed in or not — can browse videos. Posting, editing, and
    // deleting require an account. likeCount/commentCount updates happen via
    // transactions from feed.js and require sign-in.
    match /videos/{videoId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null; // needed so any signed-in user can update likeCount
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      }
    }
  }
}
